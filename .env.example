# Ariadne — environment template. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored; never commit real secrets.
#
# Load it into your shell before running the CLI:
#   set -a; source .env; set +a
#   uv run ariadne workup Halberd

# --- Required: the live agent loop calls the Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Neo4j connection (optional; these defaults match infra/neo4j/docker-compose.yml) ---
# The connector is always launched read-only regardless of these values.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# NEO4J_READ_TIMEOUT=30

# --- Postgres connection (optional; default matches infra/postgres/docker-compose.yml) ---
# Used by `ariadne index`, the relational store (`--sql`), and the document
# store (full-text + semantic). The connector is launched read-only (postgres-mcp
# restricted mode, ADR-0003) regardless of this value.
DATABASE_URI=postgresql://ariadne:ariadne@localhost:5432/intel

# --- Hugging Face (optional) — the `enron`/`worldspeech` datasets stream from the Hub ---
# Not required: corpora are public and stream anonymously. Set a READ-ONLY token
# (huggingface.co/settings/tokens) to lift the anonymous rate limit (3,000 ->
# 5,000 resolver requests / 5 min) if you hit 429s on repeated runs.
# HF_TOKEN=hf_...
#
# Caching (best practice): the `datasets` lib already caches + reuses downloads by
# default (~/.cache/huggingface). HF_HOME relocates ALL HF caches with one knob —
# set it to keep the cache on a chosen disk / inside an enclave; re-runs then hit
# the local cache instead of re-fetching from the Hub.
# HF_HOME=~/.cache/huggingface
# Optional faster downloads on high-bandwidth links (needs `pip install hf_transfer`):
# HF_HUB_ENABLE_HF_TRANSFER=1
