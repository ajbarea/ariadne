# Ariadne — environment template. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored; never commit real secrets.
#
# Load it into your shell before running the CLI:
#   set -a; source .env; set +a
#   uv run ariadne workup Halberd

# --- Required: the live agent loop calls the Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Neo4j connection (optional; these defaults match infra/neo4j/docker-compose.yml) ---
# The connector is always launched read-only regardless of these values.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# NEO4J_READ_TIMEOUT=30

# --- Hugging Face (optional) — only the `enron` dataset streams from the HF Hub ---
# Not required: the corpus is public and streams anonymously. Set a READ-ONLY
# token (huggingface.co/settings/tokens) to lift the anonymous rate limit
# (3,000 -> 5,000 resolver requests / 5 min) if you hit 429s on repeated runs.
# HF_TOKEN=hf_...
